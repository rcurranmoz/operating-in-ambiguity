---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Writing"
  description="Essays on modernization, transformation, and the human side of organizational change — by Bethany J. Curran."
>
  <Nav />

  <main class="flex-1">

    <!-- Hero — The Unforeseen Ghost -->
    <section class="bg-navy text-cream">
      <div class="max-w-6xl mx-auto px-6 pt-20 pb-24 md:pt-28 md:pb-32">
        <p class="section-label mb-6 text-cream/50">Series 01 · Thinking Different in a Think-Same World</p>
        <div class="max-w-3xl">
          <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-light leading-[1.05] tracking-tight mb-4">
            The Unforeseen Ghost
          </h1>
          <p class="font-display text-2xl md:text-3xl font-light text-terracotta mb-8">
            An Evolution of Layoffs
          </p>
          <p class="font-body text-lg text-cream/70 leading-relaxed max-w-xl mb-10">
            In generations before us, being laid off was a dig at our egos. For millennials in 2026, the ghost is familiar — but we still weren't ready for the reality of living with it.
          </p>
          <div class="flex items-center gap-6">
            <a href="/writing/the-unforeseen-ghost" class="btn-primary">Read essay</a>
            <span class="font-body text-sm text-cream/40">10 min read</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Series card -->
    <section class="max-w-6xl mx-auto px-6 py-20">
      <div class="max-w-3xl">
        <p class="section-label mb-6">The series</p>
        <div class="border border-cream-dark rounded-sm p-8 md:p-10">
          <h2 class="font-display text-3xl md:text-4xl text-navy font-light leading-tight mb-3">
            Thinking Different in a Think-Same World
          </h2>
          <p class="font-body text-base text-charcoal/60 leading-relaxed mb-10">
            On modernization, late blooming, and learning to see hard experiences through a different lens.
          </p>
          <ol class="space-y-5">
            {[
              { n: '01', title: 'The Unforeseen Ghost', subtitle: 'An Evolution of Layoffs', slug: 'the-unforeseen-ghost', active: true },
              { n: '02', title: 'Leggings Aren\'t Pants', subtitle: 'How I\'m Always Late to the Game', slug: 'leggings-arent-pants', active: false },
              { n: '03', title: 'The Tetris Method', subtitle: null, slug: 'the-tetris-method', active: false },
              { n: '04', title: 'Richard, Sally and Heiny Zero', subtitle: null, slug: 'richard-sally-and-heiny-zero', active: false },
              { n: '05', title: 'Hired at 25', subtitle: null, slug: 'hired-at-25', active: false },
              { n: '06', title: 'The Foreseen Ghost', subtitle: 'Laid Off by Design', slug: null, active: false },
            ].map(item => (
              <li class="flex items-baseline gap-5">
                <span class="font-display text-2xl text-terracotta/30 font-light shrink-0 w-8">{item.n}</span>
                <div>
                  {item.slug ? (
                    <a href={`/writing/${item.slug}`} class="font-body text-sm font-500 text-navy hover:text-terracotta transition-colors">
                      {item.title}{item.subtitle ? <span class="text-charcoal/40"> — {item.subtitle}</span> : null}
                    </a>
                  ) : (
                    <span class="font-body text-sm text-charcoal/30">
                      {item.title}{item.subtitle ? <span> — {item.subtitle}</span> : null}
                    </span>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- Substack nudge -->
    <section class="max-w-6xl mx-auto px-6 pb-24">
      <div class="max-w-3xl">
        <p class="font-body text-sm text-charcoal/50 leading-relaxed">
          All essays are also published on
          <a href="https://operatinginambiguity.substack.com" target="_blank" rel="noopener noreferrer" class="text-terracotta hover:text-navy transition-colors">Substack</a>.
          Follow there to get new essays in your inbox.
        </p>
      </div>
    </section>

  </main>

  <Footer />
</Base>
