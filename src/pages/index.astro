---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Nav />

  <main class="flex-1">

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 pt-16 pb-20 md:pt-20 md:pb-24">
      <div class="flex flex-col items-center text-center mb-16">
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl text-navy leading-[0.95] tracking-tight mb-6">
          Operating in Ambiguity
        </h1>
        <p class="font-body text-lg md:text-xl text-charcoal/70 max-w-2xl leading-relaxed">
          ...coming soon...
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-start">

        <!-- Quirky summary (copy TBD from Bethany) -->
        <div>
          <p class="font-body text-lg text-charcoal/50 leading-relaxed italic">
            Quirky 2–3 sentence summary about the purpose of this page. TBD.
          </p>
        </div>

        <!-- Contact / Substack -->
        <div class="flex flex-col items-start gap-5">
          <a
            href="mailto:bethany.curran@icloud.com?subject=Hello"
            class="btn-primary"
          >
            Contact Me
          </a>
          <a
            href="https://operatinginambiguity.substack.com"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-charcoal/50 hover:text-terracotta transition-colors"
          >
            Follow on Substack
          </a>
        </div>

      </div>
    </section>

    <!-- Featured Essays -->
    <section class="max-w-6xl mx-auto px-6 pb-24">
      <p class="section-label mb-10">Featured Essays</p>
      <div class="grid md:grid-cols-3 gap-6">

        <div class="border border-cream-dark p-8 flex flex-col gap-5">
          <div>
            <p class="font-body text-xs font-semibold tracking-widest uppercase text-navy mb-1">The Foreseen Ghost</p>
            <p class="font-body text-sm text-charcoal/60">Laid Off by Design</p>
          </div>
          <p class="font-body text-sm text-charcoal/70 leading-relaxed flex-1">
            What happens when you engineer your own exit — and the measure of success is no longer being needed?
          </p>
          <a href="/writing/the-foreseen-ghost" class="nav-link text-sm">read more...</a>
        </div>

        <div class="border border-cream-dark p-8 flex flex-col gap-5">
          <div>
            <p class="font-body text-xs font-semibold tracking-widest uppercase text-navy mb-1">The Unforeseen Ghost</p>
            <p class="font-body text-sm text-charcoal/60">An Evolution of Layoffs</p>
          </div>
          <p class="font-body text-sm text-charcoal/70 leading-relaxed flex-1">
            For millennials in 2026, the ghost is familiar — but we still weren't ready for the reality of living with it.
          </p>
          <a href="/writing/the-unforeseen-ghost" class="nav-link text-sm">read more...</a>
        </div>

        <!-- Placeholder for third essay -->
        <div class="border border-dashed border-cream-dark p-8 flex flex-col gap-5 opacity-40">
          <div>
            <p class="font-body text-xs font-semibold tracking-widest uppercase text-navy mb-1">Coming Soon</p>
            <p class="font-body text-sm text-charcoal/60">Essay in progress</p>
          </div>
          <p class="font-body text-sm text-charcoal/70 leading-relaxed flex-1">&nbsp;</p>
        </div>

      </div>
    </section>

    <!-- Frameworks -->
    <section class="max-w-6xl mx-auto px-6 pb-24">
      <p class="section-label mb-10">Frameworks</p>
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Placeholder for first framework -->
        <div class="border border-dashed border-cream-dark p-8 flex flex-col gap-5 opacity-40">
          <div>
            <p class="font-body text-xs font-semibold tracking-widest uppercase text-navy mb-1">Coming Soon</p>
            <p class="font-body text-sm text-charcoal/60">Framework in progress</p>
          </div>
          <p class="font-body text-sm text-charcoal/70 leading-relaxed flex-1">&nbsp;</p>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Base>
