---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  subtitle: string;
  date: string;
  readTime: string;
  description?: string;
  substackUrl?: string;
}

const { title, subtitle, date, readTime, description, substackUrl } = Astro.props;
---

<Base title={title} description={description ?? subtitle}>
  <Nav />

  <main class="flex-1">
    <!-- Post header -->
    <header class="max-w-3xl mx-auto px-6 pt-20 pb-12">
      <a href="/writing" class="section-label hover:text-navy transition-colors flex items-center gap-2 mb-8">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M10 6H2M5 2L1 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All writing
      </a>

      <div class="flex items-center gap-4 mb-6">
        <span class="section-label">{date}</span>
        <span class="text-charcoal/30">·</span>
        <span class="font-body text-xs text-charcoal/50">{readTime}</span>
      </div>

      <h1 class="font-display text-5xl md:text-6xl text-navy font-light leading-tight mb-3">
        {title}
      </h1>
      <p class="font-display text-2xl text-charcoal/60 italic">{subtitle}</p>

      {substackUrl && (
        <div class="mt-8 pt-8 border-t border-cream-dark">
          <a
            href={substackUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-charcoal/60 hover:text-terracotta transition-colors flex items-center gap-2"
          >
            Also published on Substack
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      )}
    </header>

    <!-- Decorative rule -->
    <div class="max-w-3xl mx-auto px-6">
      <div class="flex items-center gap-3">
        <div class="flex-1 h-px bg-cream-dark"></div>
        <span class="w-1.5 h-1.5 rounded-full bg-terracotta"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-sage"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-mustard"></span>
        <div class="flex-1 h-px bg-cream-dark"></div>
      </div>
    </div>

    <!-- Post body -->
    <article class="max-w-3xl mx-auto px-6 py-16">
      <div class="prose prose-oia max-w-none">
        <slot />
      </div>
    </article>

    <!-- Post footer CTA -->
    <div class="border-t border-cream-dark bg-cream-dark/30">
      <div class="max-w-3xl mx-auto px-6 py-16 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
        <div>
          <p class="section-label mb-3">Let's connect</p>
          <p class="font-display text-2xl text-navy">If this resonates, I'd love to talk.</p>
        </div>
        <a
          href="https://www.linkedin.com/in/bethanyjcurran/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary shrink-0"
        >
          Connect on LinkedIn
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2 12L12 2M12 2H5M12 2V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
