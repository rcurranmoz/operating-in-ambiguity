---
const year = new Date().getFullYear();
---

<footer class="border-t border-cream-dark bg-cream mt-auto">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="font-display text-2xl text-navy mb-1">Bethany J. Curran</p>
        <p class="font-body text-sm text-charcoal/60">Modernization & Transformation Leader</p>
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <nav class="flex gap-8">
          <a href="/about" class="nav-link">About</a>
          <a href="/writing" class="nav-link">Writing</a>
          <a href="/work" class="nav-link">Work</a>
        </nav>
        <a
          href="https://www.linkedin.com/in/bethanyjcurran/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline text-xs py-2 px-5"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-cream-dark flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="font-body text-xs text-charcoal/40">© {year} Bethany J. Curran. All rights reserved.</p>
      <div class="flex items-center gap-1">
        <!-- MCM geometric accent -->
        <span class="w-2 h-2 rounded-full bg-terracotta"></span>
        <span class="w-2 h-2 rounded-full bg-sage"></span>
        <span class="w-2 h-2 rounded-full bg-mustard"></span>
      </div>
    </div>
  </div>
</footer>
