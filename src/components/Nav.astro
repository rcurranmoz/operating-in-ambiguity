---
const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? currentPath === '/' : currentPath.startsWith(path);
const isFrameworksActive = currentPath.startsWith('/frameworks');
---

<header class="w-full border-b border-cream-dark bg-cream/95 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="block hover:opacity-80 transition-opacity">
      <img src="/logo.png" alt="Operating in Ambiguity" class="h-10 w-auto" />
    </a>

    <ul class="hidden md:flex items-center gap-10">
      <li>
        <a href="/writing" class:list={['nav-link', { 'text-terracotta': isActive('/writing') }]}>
          Writing
        </a>
      </li>
      <li>
        <a href="/frameworks" class:list={['nav-link', { 'text-terracotta': isFrameworksActive }]}>
          Frameworks
        </a>
      </li>
    </ul>

    <!-- Mobile menu toggle -->
    <button id="menu-btn" class="md:hidden p-2 text-navy" aria-label="Open menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-cream-dark bg-cream px-6 py-6">
    <ul class="flex flex-col gap-6">
      <li><a href="/writing" class="nav-link">Writing</a></li>
      <li><a href="/frameworks" class="nav-link">Frameworks</a></li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
